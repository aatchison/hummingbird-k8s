# Pinned by digest (OCI index, multi-arch) for reproducibility. Bump deliberately;
# see PR description for the procedure (`skopeo inspect docker://...:latest`).
FROM quay.io/hummingbird-community/bootc-os@sha256:3bed2fc1bd96ad56a3e4357270ff0f22286fb41c9e00b4f3c9a862696e3bfb84

# K8S_VERSION is the pkgs.k8s.io repo channel (major.minor only — the upstream
# repo URL doesn't accept a patch version). At build time dnf installs the
# newest 1.31.x available; the resulting image is reproducible as long as the
# base digest above is pinned and the upstream repo is content-addressable per
# build. Bump deliberately (e.g., v1.32) when promoting to a new minor release.
ARG K8S_VERSION=v1.31
ARG POD_CIDR=10.244.0.0/16
ARG APISERVER_EXTRA_SANS=127.0.0.1,localhost

# Drop in the sshd config early so changes here don't bust the (much bigger)
# package-install layer cache below.
COPY containers/shared/ssh/99-no-passwords.conf /etc/ssh/sshd_config.d/99-no-passwords.conf

# Hummingbird's curated repo doesn't carry the standard k8s deps (iptables, socat,
# conntrack-tools, ethtool). Add Fedora Rawhide as a secondary source — Hummingbird
# is Rawhide-based so versions are compatible. gpgcheck=0 to avoid bootstrapping
# Fedora's GPG keyring into this image; flip on once the workflow is settled.
RUN printf '[fedora-rawhide]\nname=Fedora Rawhide\nmetalink=https://mirrors.fedoraproject.org/metalink?repo=rawhide&arch=$basearch\nenabled=1\ngpgcheck=0\nskip_if_unavailable=False\n' \
      > /etc/yum.repos.d/fedora-rawhide.repo

# Upstream Kubernetes + CRI-O RPM repos (version-aligned)
RUN printf '[kubernetes]\nname=Kubernetes\nbaseurl=https://pkgs.k8s.io/core:/stable:/%s/rpm/\nenabled=1\ngpgcheck=1\ngpgkey=https://pkgs.k8s.io/core:/stable:/%s/rpm/repodata/repomd.xml.key\n' "$K8S_VERSION" "$K8S_VERSION" \
      > /etc/yum.repos.d/kubernetes.repo \
 && printf '[cri-o]\nname=CRI-O\nbaseurl=https://pkgs.k8s.io/addons:/cri-o:/stable:/%s/rpm/\nenabled=1\ngpgcheck=1\ngpgkey=https://pkgs.k8s.io/addons:/cri-o:/stable:/%s/rpm/repodata/repomd.xml.key\n' "$K8S_VERSION" "$K8S_VERSION" \
      > /etc/yum.repos.d/cri-o.repo

RUN dnf install -y \
      cri-o kubelet kubeadm kubectl \
      iptables-nft iproute-tc socat conntrack-tools ethtool \
 && dnf clean all

# Pre-create the flex-volume plugin dir. kube-controller-manager mounts this
# HostPath with DirectoryOrCreate and tries to mkdir at runtime, which fails on
# bootc's read-only /usr. Creating it at image build avoids the mkdir entirely.
RUN mkdir -p /usr/libexec/kubernetes/kubelet-plugins/volume/exec

# Kernel modules + sysctls required by kubeadm.
# The vm.* / kernel.panic* / kernel.keys.* entries match the values the kubelet
# expects when --protect-kernel-defaults=true (CIS 4.2.6): with that flag set
# the kubelet refuses to mutate kernel parameters at runtime and instead
# requires the host to have them pre-set to the expected values.
RUN printf 'overlay\nbr_netfilter\n' > /etc/modules-load.d/k8s.conf \
 && printf 'net.bridge.bridge-nf-call-iptables  = 1\nnet.bridge.bridge-nf-call-ip6tables = 1\nnet.ipv4.ip_forward                 = 1\nvm.overcommit_memory                = 1\nvm.panic_on_oom                     = 0\nkernel.panic                        = 10\nkernel.panic_on_oops                = 1\nkernel.keys.root_maxkeys            = 1000000\nkernel.keys.root_maxbytes           = 25000000\n' \
      > /etc/sysctl.d/k8s.conf

# Bake build-time config into an env file the first-boot script sources.
RUN mkdir -p /etc/hummingbird \
 && printf 'POD_CIDR=%s\nAPISERVER_EXTRA_SANS=%s\n' "$POD_CIDR" "$APISERVER_EXTRA_SANS" \
      > /etc/hummingbird/k8s-init.env

# First-boot script: kubeadm init + flannel + untaint, then mark complete.
COPY containers/k8s/k8s-init.sh /usr/libexec/k8s-init.sh
RUN chmod +x /usr/libexec/k8s-init.sh

# Ship the etcd encryption verifier in the image so the deploy verifier can
# run it directly over SSH: `ssh root@<cp> /usr/libexec/verify-encryption.sh`
# — no scp from the host repo needed after every redeploy.
COPY scripts/verify-encryption.sh /usr/libexec/verify-encryption.sh
RUN chmod +x /usr/libexec/verify-encryption.sh

COPY containers/k8s/k8s-init.service /etc/systemd/system/k8s-init.service

# Hummingbird ships a 99-default-disable.preset that strips unenabled symlinks
# during image build. Override with a low-numbered preset that wins.
COPY containers/k8s/10-k8s.preset /usr/lib/systemd/system-preset/10-k8s.preset
RUN systemctl preset crio.service kubelet.service k8s-init.service || true

# Security hardening config files (PodSecurity Admission + apiserver audit policy).
# Read-only references mounted into the apiserver static pod by k8s-init.sh.
COPY containers/shared/kubernetes/admission-control-config.yaml /etc/kubernetes/admission-control-config.yaml
COPY containers/shared/kubernetes/audit-policy.yaml /etc/kubernetes/audit-policy.yaml

# Cluster-wide baseline posture applied by k8s-init.sh after Cilium is up:
#   - metrics-server (kubectl top) — upstream v0.7.2, patched for --kubelet-insecure-tls
#   - default namespace LimitRange + ResourceQuota
#   - default ServiceAccount in default namespace: automountServiceAccountToken=false
COPY containers/shared/kubernetes/metrics-server.yaml /etc/kubernetes/metrics-server.yaml
COPY containers/shared/kubernetes/default-ns-quota.yaml /etc/kubernetes/default-ns-quota.yaml
COPY containers/shared/kubernetes/restrict-sa-token-mount.yaml /etc/kubernetes/restrict-sa-token-mount.yaml

# cilium-cli (single binary) used by k8s-init.sh to install Cilium CNI on first boot.
#
# Integrity floor: sha256 from the upstream-published .sha256sum (verified below).
# Cosign verification is NOT applied here: cilium-cli releases through v0.16.x do
# not publish detached .sig/.pem artifacts in their GitHub release assets (only
# .sha256sum). When the cilium-cli release stream starts shipping Sigstore
# signatures (or moves to a Rekor-bundle workflow), this block should grow a
# `cosign verify-blob` step. Tracked in #72.
#
# Network resilience: each curl uses --retry to ride out transient GitHub
# blips. There is no independent third-party mirror for cilium-cli release
# artifacts (the project distributes only via github.com), so the "fallback"
# here is in-attempt retry rather than a second host. Tracked in #97.
ARG CILIUM_CLI_VERSION=v0.16.16
RUN curl -fsSL --retry 3 --retry-delay 2 -o /tmp/cilium-linux-amd64.tar.gz \
      "https://github.com/cilium/cilium-cli/releases/download/${CILIUM_CLI_VERSION}/cilium-linux-amd64.tar.gz" \
 && curl -fsSL --retry 3 --retry-delay 2 -o /tmp/cilium-linux-amd64.tar.gz.sha256sum \
      "https://github.com/cilium/cilium-cli/releases/download/${CILIUM_CLI_VERSION}/cilium-linux-amd64.tar.gz.sha256sum" \
 && (cd /tmp && sha256sum -c cilium-linux-amd64.tar.gz.sha256sum) \
 && tar -C /usr/bin -xzf /tmp/cilium-linux-amd64.tar.gz cilium \
 && rm -f /tmp/cilium-linux-amd64.tar.gz /tmp/cilium-linux-amd64.tar.gz.sha256sum \
 && /usr/bin/cilium version --client

LABEL containers.bootc=1
LABEL org.opencontainers.image.source=https://github.com/aatchison/hummingbird-k8s
LABEL org.opencontainers.image.description="Fedora Hummingbird bootc image with upstream Kubernetes (kubelet/kubeadm/cri-o), control plane"
