# Pinned by digest (OCI index, multi-arch) for reproducibility. Bump deliberately;
# see PR description for the procedure (`skopeo inspect docker://...:latest`).
FROM quay.io/hummingbird-community/bootc-os@sha256:3bed2fc1bd96ad56a3e4357270ff0f22286fb41c9e00b4f3c9a862696e3bfb84

# K8S_VERSION pins the major.minor only (e.g. v1.31). pkgs.k8s.io URLs are
# major.minor-scoped, so dnf installs the latest 1.31.x patch at build time.
# This means patch-level CVE fixes ride in on every rebuild without manual
# bumps; the trade-off is determinism — two builds of the same Containerfile
# at different times can produce different images. Acceptable for a lab.
#
# Note: this is intentionally different from the k3s flavor's K3S_VERSION,
# which pins patch (e.g. v1.31.4+k3s1) because the k3s installer fetches a
# specific tagged binary by URL. Both flavors target the same minor channel
# (currently 1.31); bump them together when promoting to a new minor. (#82)
#
# Bump deliberately (e.g., v1.32) when promoting to a new minor release.
ARG K8S_VERSION=v1.31
ARG POD_CIDR=10.244.0.0/16
ARG APISERVER_EXTRA_SANS=127.0.0.1,localhost

# Optional cloud-init support. Default OFF — the canonical Hummingbird
# customization path is the bib `[[customizations.user]]` blocks rendered
# by lib/build-common.sh. Set ENABLE_CLOUD_INIT=1 at build time to
# additionally include the cloud-init package + enable the NoCloud
# datasource, which lets operators inject per-VM user-data (SSH keys,
# runcmd, package installs) via `virt-install --cloud-init` or a libvirt
# seed ISO. See docs/cloud-init.md.
ARG ENABLE_CLOUD_INIT=1

# Drop in the sshd config early so changes here don't bust the (much bigger)
# package-install layer cache below.
COPY containers/shared/ssh/99-no-passwords.conf /etc/ssh/sshd_config.d/99-no-passwords.conf

# Import Fedora's GPG keyring (release-aligned public-key bundle from
# fedoraproject.org) so every dnf install from the Rawhide repo below — and
# from the optional cloud-init repo — is signature-verified at install time
# (#70). The bundle ships keys for the current and adjacent Fedora releases
# (currently F42-F45); dnf picks the right one by the package's signing-key
# fingerprint at install time. Pinning the bundle URL avoids the previous
# "gpgcheck=0 to skip bootstrap" posture that left Rawhide RPMs unverified.
#
# The upstream bundle is binary-OpenPGP, but rpm --import only accepts
# ASCII-armored keys, so we re-armor via gpg before importing.
RUN curl -fsSL --retry 3 --retry-delay 2 -o /tmp/fedora.gpg \
      https://fedoraproject.org/fedora.gpg \
 && GNUPGHOME=$(mktemp -d) \
 && gpg --homedir "$GNUPGHOME" --import /tmp/fedora.gpg \
 && gpg --homedir "$GNUPGHOME" --armor --export \
      > /etc/pki/rpm-gpg/RPM-GPG-KEY-fedora \
 && rpm --import /etc/pki/rpm-gpg/RPM-GPG-KEY-fedora \
 && rm -rf "$GNUPGHOME" /tmp/fedora.gpg

# Optional cloud-init package + units. The shared datasource config + preset
# are COPY'd unconditionally (they're tiny and inert without the package),
# but the dnf install + `systemctl preset` only fire when the build arg is
# set, so the default image is byte-identical to pre-cloud-init.
#
# cloud-init pulls deps (xfsprogs, python3 modules, dhcpcd, nc) that aren't
# in Hummingbird's curated repo, so the conditional drops in Fedora Rawhide
# as a one-shot secondary source (Hummingbird is Rawhide-based) and removes
# the repo file before the layer commits. The k8s flavor's main RUN below
# adds its own permanent Rawhide repo for iptables/socat/etc; this
# self-contained drop-in keeps the cloud-init block independent of step
# ordering. gpgcheck=1 against the Fedora keyring imported above (#70).
COPY containers/shared/cloud-init/10-cloud-init.preset /usr/lib/systemd/system-preset/10-cloud-init.preset
COPY containers/shared/cloud-init/98-hummingbird-users.cfg /etc/cloud/cloud.cfg.d/98-hummingbird-users.cfg
COPY containers/shared/cloud-init/99-hummingbird-datasource.cfg /etc/cloud/cloud.cfg.d/99-hummingbird-datasource.cfg
RUN if [ "${ENABLE_CLOUD_INIT}" = "1" ]; then \
      printf '[fedora-rawhide]\nname=Fedora Rawhide\nmetalink=https://mirrors.fedoraproject.org/metalink?repo=rawhide&arch=$basearch\nenabled=1\ngpgcheck=1\ngpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-fedora\nskip_if_unavailable=False\n' \
        > /etc/yum.repos.d/fedora-rawhide-cloudinit.repo \
      && dnf install -y cloud-init cloud-utils-growpart \
      && dnf clean all \
      && rm -f /etc/yum.repos.d/fedora-rawhide-cloudinit.repo \
      && systemctl preset cloud-init-local.service \
           cloud-init-main.service cloud-init-network.service \
           cloud-config.service cloud-final.service ; \
    else \
      rm -f /usr/lib/systemd/system-preset/10-cloud-init.preset \
            /etc/cloud/cloud.cfg.d/99-hummingbird-datasource.cfg ; \
    fi

# Hummingbird's curated repo doesn't carry the standard k8s deps (iptables, socat,
# conntrack-tools, ethtool). Add Fedora Rawhide as a secondary source — Hummingbird
# is Rawhide-based so versions are compatible. gpgcheck=1 against the Fedora
# keyring imported above (#70).
RUN printf '[fedora-rawhide]\nname=Fedora Rawhide\nmetalink=https://mirrors.fedoraproject.org/metalink?repo=rawhide&arch=$basearch\nenabled=1\ngpgcheck=1\ngpgkey=file:///etc/pki/rpm-gpg/RPM-GPG-KEY-fedora\nskip_if_unavailable=False\n' \
      > /etc/yum.repos.d/fedora-rawhide.repo

# Upstream Kubernetes + CRI-O RPM repos (version-aligned)
RUN printf '[kubernetes]\nname=Kubernetes\nbaseurl=https://pkgs.k8s.io/core:/stable:/%s/rpm/\nenabled=1\ngpgcheck=1\ngpgkey=https://pkgs.k8s.io/core:/stable:/%s/rpm/repodata/repomd.xml.key\n' "$K8S_VERSION" "$K8S_VERSION" \
      > /etc/yum.repos.d/kubernetes.repo \
 && printf '[cri-o]\nname=CRI-O\nbaseurl=https://pkgs.k8s.io/addons:/cri-o:/stable:/%s/rpm/\nenabled=1\ngpgcheck=1\ngpgkey=https://pkgs.k8s.io/addons:/cri-o:/stable:/%s/rpm/repodata/repomd.xml.key\n' "$K8S_VERSION" "$K8S_VERSION" \
      > /etc/yum.repos.d/cri-o.repo

RUN dnf install -y \
      cri-o kubelet kubeadm kubectl \
      iptables-nft iproute-tc socat conntrack-tools ethtool \
 && dnf clean all

# Pre-create the flex-volume plugin dir. kube-controller-manager mounts this
# HostPath with DirectoryOrCreate and tries to mkdir at runtime, which fails on
# bootc's read-only /usr. Creating it at image build avoids the mkdir entirely.
RUN mkdir -p /usr/libexec/kubernetes/kubelet-plugins/volume/exec

# Kernel modules + sysctls required by kubeadm.
# The vm.* / kernel.panic* / kernel.keys.* entries match the values the kubelet
# expects when --protect-kernel-defaults=true (CIS 4.2.6): with that flag set
# the kubelet refuses to mutate kernel parameters at runtime and instead
# requires the host to have them pre-set to the expected values.
RUN printf 'overlay\nbr_netfilter\n' > /etc/modules-load.d/k8s.conf \
 && printf 'net.bridge.bridge-nf-call-iptables  = 1\nnet.bridge.bridge-nf-call-ip6tables = 1\nnet.ipv4.ip_forward                 = 1\nvm.overcommit_memory                = 1\nvm.panic_on_oom                     = 0\nkernel.panic                        = 10\nkernel.panic_on_oops                = 1\nkernel.keys.root_maxkeys            = 1000000\nkernel.keys.root_maxbytes           = 25000000\n' \
      > /etc/sysctl.d/k8s.conf

# Bake build-time config into an env file the first-boot script sources.
RUN mkdir -p /etc/hummingbird \
 && printf 'POD_CIDR=%s\nAPISERVER_EXTRA_SANS=%s\n' "$POD_CIDR" "$APISERVER_EXTRA_SANS" \
      > /etc/hummingbird/k8s-init.env

# First-boot script: kubeadm init + flannel + untaint, then mark complete.
COPY containers/k8s/k8s-init.sh /usr/libexec/k8s-init.sh
RUN chmod +x /usr/libexec/k8s-init.sh

# Ship the etcd encryption verifier in the image so the deploy verifier can
# run it directly over SSH: `ssh root@<cp> /usr/libexec/verify-encryption.sh`
# — no scp from the host repo needed after every redeploy.
COPY scripts/verify-encryption.sh /usr/libexec/verify-encryption.sh
RUN chmod +x /usr/libexec/verify-encryption.sh

COPY containers/k8s/k8s-init.service /etc/systemd/system/k8s-init.service

# Hummingbird ships a 99-default-disable.preset that strips unenabled symlinks
# during image build. Override with a low-numbered preset that wins.
COPY containers/k8s/10-k8s.preset /usr/lib/systemd/system-preset/10-k8s.preset
RUN systemctl preset crio.service kubelet.service k8s-init.service || true

# Security hardening config files (PodSecurity Admission + apiserver audit policy).
# Read-only references mounted into the apiserver static pod by k8s-init.sh.
COPY containers/shared/kubernetes/admission-control-config.yaml /etc/kubernetes/admission-control-config.yaml
COPY containers/shared/kubernetes/audit-policy.yaml /etc/kubernetes/audit-policy.yaml

# Cluster-wide baseline posture applied by k8s-init.sh after Cilium is up:
#   - metrics-server (kubectl top) — upstream v0.7.2, patched for --kubelet-insecure-tls
#   - default namespace LimitRange + ResourceQuota
#   - default ServiceAccount in default namespace: automountServiceAccountToken=false
COPY containers/shared/kubernetes/metrics-server.yaml /etc/kubernetes/metrics-server.yaml
COPY containers/shared/kubernetes/default-ns-quota.yaml /etc/kubernetes/default-ns-quota.yaml
COPY containers/shared/kubernetes/restrict-sa-token-mount.yaml /etc/kubernetes/restrict-sa-token-mount.yaml

# Post-upgrade health-check + auto-rollback (#104). The timer fires 3 min
# after every boot; the script only takes action when the marker file
# /var/lib/bootc-just-upgraded is present (set by an ExecStartPost drop-in
# on bootc-fetch-apply-updates.service). See docs/rollback.md.
COPY containers/shared/health-check-rollback.sh /usr/libexec/health-check-rollback.sh
COPY containers/shared/health-check-rollback.service /etc/systemd/system/health-check-rollback.service
COPY containers/shared/health-check-rollback.timer /etc/systemd/system/health-check-rollback.timer
COPY containers/shared/bootc-fetch-apply-updates.service.d/10-mark-upgrade.conf \
     /etc/systemd/system/bootc-fetch-apply-updates.service.d/10-mark-upgrade.conf
RUN chmod +x /usr/libexec/health-check-rollback.sh \
 && systemctl preset health-check-rollback.timer || true

# cilium-cli (single binary) used by k8s-init.sh to install Cilium CNI on first boot.
#
# Arch-aware: cilium-cli ships per-arch tarballs (cilium-linux-amd64.tar.gz,
# cilium-linux-arm64.tar.gz) plus matching .sha256sum files. TARGETARCH is
# set automatically by buildah/podman when --platform is passed (linux/amd64
# → amd64, linux/arm64 → arm64), so a single Containerfile services both
# manifests in the multi-arch index. Closes #111.
#
# Integrity floor: sha256 from the upstream-published .sha256sum (verified below).
# Cosign verification is NOT applied here: cilium-cli releases through v0.16.x do
# not publish detached .sig/.pem artifacts in their GitHub release assets (only
# .sha256sum). When the cilium-cli release stream starts shipping Sigstore
# signatures (or moves to a Rekor-bundle workflow), this block should grow a
# `cosign verify-blob` step. Tracked in #72.
#
# Network resilience: each curl uses --retry to ride out transient GitHub
# blips. There is no independent third-party mirror for cilium-cli release
# artifacts (the project distributes only via github.com), so the "fallback"
# here is in-attempt retry rather than a second host. Tracked in #97.
ARG TARGETARCH
ARG CILIUM_CLI_VERSION=v0.16.16
RUN curl -fsSL --retry 3 --retry-delay 2 -o "/tmp/cilium-linux-${TARGETARCH}.tar.gz" \
      "https://github.com/cilium/cilium-cli/releases/download/${CILIUM_CLI_VERSION}/cilium-linux-${TARGETARCH}.tar.gz" \
 && curl -fsSL --retry 3 --retry-delay 2 -o "/tmp/cilium-linux-${TARGETARCH}.tar.gz.sha256sum" \
      "https://github.com/cilium/cilium-cli/releases/download/${CILIUM_CLI_VERSION}/cilium-linux-${TARGETARCH}.tar.gz.sha256sum" \
 && (cd /tmp && sha256sum -c "cilium-linux-${TARGETARCH}.tar.gz.sha256sum") \
 && tar -C /usr/bin -xzf "/tmp/cilium-linux-${TARGETARCH}.tar.gz" cilium \
 && rm -f "/tmp/cilium-linux-${TARGETARCH}.tar.gz" "/tmp/cilium-linux-${TARGETARCH}.tar.gz.sha256sum" \
 && /usr/bin/cilium version --client

LABEL containers.bootc=1
LABEL org.opencontainers.image.source=https://github.com/aatchison/hummingbird-k8s
LABEL org.opencontainers.image.description="Fedora Hummingbird bootc image with upstream Kubernetes (kubelet/kubeadm/cri-o), control plane"
