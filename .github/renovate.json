{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies", "renovate"],
  "prConcurrentLimit": 5,
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchPackageNames": ["kubernetes/kubernetes", "cilium/cilium-cli"],
      "groupName": "kubernetes-tooling"
    },
    {
      "matchPackageNames": ["quay.io/hummingbird-community/bootc-os"],
      "groupName": "bootc-os-base",
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^containers/.*/Containerfile$"],
      "matchStrings": [
        "ARG CILIUM_CLI_VERSION=(?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "cilium/cilium-cli",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^containers/.*/Containerfile$"],
      "matchStrings": [
        "ARG K8S_VERSION=(?<currentValue>v[0-9.]+)"
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-releases"
    },
    {
      "customType": "regex",
      "fileMatch": ["^containers/.*/Containerfile$", "^lib/build-common\\.sh$"],
      "matchStrings": [
        "quay\\.io/hummingbird-community/bootc-os@(?<currentDigest>sha256:[a-f0-9]{64})"
      ],
      "depNameTemplate": "quay.io/hummingbird-community/bootc-os",
      "packageNameTemplate": "quay.io/hummingbird-community/bootc-os",
      "datasourceTemplate": "docker",
      "currentValueTemplate": "latest"
    }
  ]
}
